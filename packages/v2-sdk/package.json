{
  "name": "@hop-protocol/v2-sdk",
  "version": "0.0.0-beta.21",
  "description": "The Hop Protocol v2 TypeScript SDK",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "dev": "npm run version && tsc --watch",
    "build": "pnpm version && pnpm build:all",
    "build:ts": "tsc",
    "build:cjs": "tsc -p tsconfig.cjs.json && echo '{\"type\": \"commonjs\", \"imports\": { \"#*\": \"./*\" }}' > dist/cjs/package.json",
    "build:esm": "tsc -p tsconfig.esm.json && echo '{\"type\": \"module\", \"imports\": { \"#*\": \"./*\" }}' > dist/esm/package.json && npx --yes fix-esm-import-path dist/esm/config/contracts/ && sh ./scripts/update_exports.sh",
    "build:all": "pnpm build:typechain && pnpm build:esm && pnpm build:cjs",
    "build:browser": "esbuild dist/cjs/index.js --bundle --minify --platform=browser --outfile=hop.js",
    "build:typechain": "typechain --target=ethers-v5 --out-dir=./src/config/contracts ./src/config/abi/**/*.json && sh ./scripts/ts-nocheck.sh",
    "clean": "rimraf dist && rimraf hop.js",
    "clean:docs": "rimraf docs",
    "clean:docs-ui": "rimraf docs-ui",
    "version": "echo \"export default '$(cat package.json | jq -r '.version')'\" > src/version.ts",
    "lint": "eslint . --ext .ts --fix",
    "version:bump": "npm version prerelease --preid=beta",
    "publish:latest": "npm publish --tag latest --access public",
    "publish:beta": "npm publish --tag beta --access public",
    "publish:next": "npm publish --tag next --access public",
    "lerna:sync": "npx lerna-sync-version",
    "release": "npm run clean && npm test && npm run publish:latest",
    "bump-release": "npm run version:bump && npm run lerna:sync && npm run release",
    "docs:markdown": "npm run clean:docs && typedoc --plugin typedoc-plugin-markdown --theme markdown --hideGenerator --excludeExternals --excludePrivate --disableSources --hideBreadcrumbs --namedAnchors --out docs src/index.ts",
    "docs:concat": "npm run clean:docs && typedoc --plugin typedoc-plugin-markdown --theme markdown --hideGenerator --excludeExternals --excludePrivate --disableSources --hideBreadcrumbs --namedAnchors --out docs src/index.ts && npx concat-md --toc --decrease-title-levels --dir-name-as-title docs > docs/README.md",
    "docs:ui": "npm run clean:docs-ui && typedoc --out docs-ui src/index.ts",
    "docs": "npm run docs:ui && npm run docs:markdown"
  },
  "directories": {},
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@arbitrum/sdk": "2.0.18",
    "@eth-optimism/contracts": "^0.5.3",
    "@eth-optimism/message-relayer": "^0.2.18",
    "@eth-optimism/sdk": "^3.1.4",
    "@fxportal/maticjs-fxportal": "1.1.1",
    "@maticnetwork/maticjs": "3.2.0",
    "@maticnetwork/maticjs-ethers": "1.0.2",
    "dotenv": "^16.0.3",
    "ethers": "5.7.1",
    "eventemitter3": "4.0.7",
    "fast-memoize": "2.5.2",
    "isomorphic-fetch": "3.0.0",
    "lodash": "^4.17.21",
    "luxon": "2.5.0",
    "merkletreejs": "^0.2.32",
    "p-queue": "8.0.1",
    "wait": "^0.4.2",
    "web3-utils": "1.7.5"
  },
  "devDependencies": {
    "@types/isomorphic-fetch": "0.0.35",
    "@types/jest": "^27.0.3",
    "@types/lodash": "^4.14.190",
    "@types/luxon": "^1.27.1",
    "@types/node": "20.11.22",
    "@types/node-fetch": "2.6.11",
    "browserify": "^16.5.0",
    "eslint": "^7.30.0",
    "eslint-config-standard": "^16.0.3",
    "eslint-plugin-import": "^2.23.4",
    "eslint-plugin-jest": "^24.3.6",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^5.1.0",
    "eslint-plugin-sort-imports-es6-autofix": "^0.6.0",
    "eslint-plugin-unused-imports": "^1.1.2",
    "jest": "^26.6.3",
    "lerna-sync-version": "^0.0.6",
    "rimraf": "^3.0.2",
    "standard": "^12.0.1",
    "ts-jest": "^26.5.4",
    "tsify": "^4.0.1",
    "typedoc": "^0.25.1",
    "typedoc-plugin-markdown": "^3.16.0",
    "@typechain/ethers-v5": "10.1.0",
    "typechain": "8.1.0"
  },
  "imports": {
    "#*": "./dist/esm/*"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "default": "./dist/cjs/index.js"
    }
  }
}
